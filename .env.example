# 数据库配置示例文件
# 复制此文件为 .env 并填写实际配置
# 
# 注意：通过 DB_USE_PRO 环境变量控制使用哪个数据库环境
# DB_USE_PRO=true  → 使用生产环境数据库（默认）
# DB_USE_PRO=false → 使用开发环境数据库

# ==================== 数据库环境选择 ====================
DB_USE_PRO=true

# ==================== 开发环境数据库配置 ====================
# DB_HOST=localhost
# DB_PORT=3306
# DB_USER=root
# DB_PASSWORD=root
# DB_NAME=akshare

# ==================== 生产环境数据库配置（默认启用）====================
DB_PRO_HOST=8.137.104.120
DB_PRO_PORT=3306
DB_PRO_USER=root
DB_PRO_PASSWORD=root1314pwd
DB_PRO_NAME=akshare
